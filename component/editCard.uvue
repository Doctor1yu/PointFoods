<template>
	<view class="card">
		<image class="img" :src="item.image" mode="aspectFill" />

		<view class="main">
			<view class="row1">
				<view class="name">{{ item.name }}</view>
				<view class="actions">
					<view class="icon-btn" @click="emit('edit', item)">✎</view>
					<view class="icon-btn danger" @click="emit('delete', item)">🗑</view>
				</view>
			</view>

			<view class="desc">{{ item.description ?? item.desc }}</view>

			<view class="row3">
				<view class="price">¥{{ item.price }}</view>
				<view class="cat">{{ item.category }}</view>
			</view>
		</view>
	</view>
</template>

<script setup>
	type FoodItem = {
		id: string | number
		name: string
		price: number | string
		category?: string
		desc?: string
		description?: string
		image: string
	}

	defineProps<{
		item: FoodItem
	}>()

	const emit = defineEmits<{
		(e: 'edit', item: FoodItem): void
		(e: 'delete', item: FoodItem): void
	}>()
</script>

