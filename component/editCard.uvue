		justify-content: space-between;
	}

	.name {
		font-size: 18px;
		font-weight: 800;
		color: #111827;
	}

	.actions {
		flex-direction: row;
		align-items: center;
	}

	.icon-btn {
		width: 32px;
		height: 32px;
		border-radius: 10px;
