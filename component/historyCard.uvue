	}

	.status {
		padding: 4px 10px;
		border-radius: 999px;
		background-color: rgba(17, 24, 39, 0.06);
		color: rgba(17, 24, 39, 0.75);
		font-size: 12px;
		font-weight: 800;
	}

	.divider {
		height: 1px;
		background-color: rgba(17, 24, 39, 0.06);
		margin: 10px 0;
	}

	.item-row {
		flex-direction: row;
		align-items: center;
		justify-content: space-between;
		padding: 8px 0;
	}

	.left {
		flex-direction: row;
		align-items: baseline;
	}

	.name {
		font-size: 14px;
		font-weight: 800;
		color: rgba(17, 24, 39, 0.9);
	}

	.qty {
		font-size: 13px;
