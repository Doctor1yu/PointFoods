<template>
	<view class="card">
		<view class="header">
			<view class="time">
				<text class="icon">📅</text>
				<text class="t">{{ order.time }}</text>
			</view>
			<view class="status">{{ order.status }}</view>
		</view>

		<view class="divider"></view>

		<view class="items">
			<view v-for="(it, idx) in order.items" :key="idx" class="item-row">
				<view class="left">
					<text class="name">{{ it.name }}</text>
					<text class="qty"> x{{ it.qty }}</text>
				</view>
				<view class="right">¥{{ formatMoney(it.price * it.qty) }}</view>
			</view>
		</view>

		<view class="footer">
			<view class="count">共 {{ totalCount }} 件</view>
			<view class="sum">
				<text class="sum-label">总计</text>
				<text class="sum-money">¥{{ formatMoney(totalMoney) }}</text>
			</view>
		</view>
	</view>
</template>

<script setup>
	import { computed } from 'vue'

	type OrderItem = {
		name: string
		qty: number
		price: number
	}

	type Order = {
		id: string | number
		time: string
		status: string
		items: OrderItem[]
	}

	const props = defineProps<{
		order: Order
	}>()

	const totalCount = computed(() => props.order.items.reduce((s, it) => s + (Number(it.qty) || 0), 0))
	const totalMoney = computed(() =>
		props.order.items.reduce((s, it) => s + (Number(it.qty) || 0) * (Number(it.price) || 0), 0)
	)

	function formatMoney(n: number) {
		const v = Number(n) || 0
		return v.toFixed(2)
	}
</script>

